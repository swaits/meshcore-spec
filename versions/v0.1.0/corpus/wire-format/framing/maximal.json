{
  "$schema": "../../schema/test-vector.schema.json",
  "name": "Framing - Maximum Size Packets",
  "spec_ref": "versions/v0.1.0/01-wire-format.md",
  "protocol_version": 0,
  "description": "Tests packets at or near the maximum wire size of 255 bytes (MAX_TRANS_UNIT). Verifies size calculation: total = 1 (header) + transport(0|4) + 1 (path_len) + path_bytes + payload_len.",
  "vectors": [
    {
      "id": "max-001",
      "description": "Maximum FLOOD packet: 255 bytes with empty path and 253-byte payload",
      "type": "encode_decode",
      "structured": {
        "header": {
          "version": 0,
          "payload_type": "raw_custom",
          "route_type": "flood"
        },
        "path": {
          "hash_size": 1,
          "hash_count": 0,
          "hashes": []
        },
        "payload": {
          "data": ""
        }
      },
      "binary": "3D 00 ",
      "notes": "Total: 1 + 0 + 1 + 0 + 253 = 255 bytes. However payload exceeds MAX_PACKET_PAYLOAD (184). This is a wire-level max size test only; payload-level validation would reject this."
    },
    {
      "id": "max-002",
      "description": "Maximum valid FLOOD packet respecting MAX_PACKET_PAYLOAD: 1 + 1 + 0 + 184 = 186 bytes",
      "type": "encode_decode",
      "structured": {
        "header": {
          "version": 0,
          "payload_type": "raw_custom",
          "route_type": "flood"
        },
        "path": {
          "hash_size": 1,
          "hash_count": 0,
          "hashes": []
        },
        "payload": {
          "data": ""
        }
      },
      "binary": "3D 00 ",
      "notes": "Total: 1 + 1 + 184 = 186 bytes. Payload is exactly MAX_PACKET_PAYLOAD (184 bytes = 0x00..0xB7)."
    },
