          "hash_count": 0,
          "hashes": []
        },
        "payload": {
          "data": "01 AABBCCDD"
        }
      },
      "binary": "2D 00 01 AABBCCDD",
      "notes": "control_byte=0x01: bit 7 clear, multi-hop allowed."
    },
    {
      "id": "ctl-002",
      "description": "Control packet with zero-hop only (bit 7 set)",
      "type": "encode_decode",
      "structured": {
        "header": {
          "version": 0,
          "payload_type": "control",
          "route_type": "direct"
        },
        "path": {
          "hash_size": 1,
          "hash_count": 0,
          "hashes": []
        },
        "payload": {
          "data": "80 AABBCCDD"
        }
      },
      "binary": "2E 00 80 AABBCCDD",
      "notes": "control_byte=0x80: bit 7 set, zero-hop only. Direct route with path_count=0 = zero-hop."
    },
    {
