          "hash_size": 1,
          "hash_count": 0,
          "hashes": []
        },
        "payload": {
          "dest_hash": "AB",
          "src_hash": "CD",
          "cipher_mac": "1122",
          "ciphertext": "DEADBEEFCAFEBABE0102030405060708"
        }
      },
      "binary": "01 00 ABCD 1122 DEADBEEFCAFEBABE0102030405060708",
      "notes": "Header: (0<<6)|(0<<2)|1 = 0x01. Payload: dest_hash(1) + src_hash(1) + MAC(2) + 16 bytes ciphertext."
