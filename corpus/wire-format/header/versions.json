      "type": "encode_decode",
      "structured": {
        "header": {
          "version": 0,
          "payload_type": "ack",
          "route_type": "flood"
        },
        "path": {
          "hash_size": 1,
          "hash_count": 0,
          "hashes": []
        },
        "payload": {
          "ack_crc": "00000001"
        }
      },
      "binary": "0D 00 01000000",
      "notes": "Header: (0<<6)|(3<<2)|1 = 0x0D. Version 0 = V1."
    },
    {
      "id": "ver-001",
      "description": "Version 1 (V2, reserved) - bits 6-7 = 01",
